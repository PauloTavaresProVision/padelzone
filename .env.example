# ── PadelZone — variáveis de ambiente ──
# Copia este ficheiro para .env e preenche os valores.
# NUNCA versiones o .env (tem segredos) — já está no .gitignore.

# Segredo das sessões (HMAC). OBRIGATÓRIO em produção.
# Gera um valor forte:  openssl rand -hex 32
AUTH_SECRET=

# Base de dados.
# No Docker (docker compose) este valor é SOBREPOSTO para apontar ao serviço "db".
# Só precisas de o ajustar se correres o Prisma fora do Docker.
DATABASE_URL="postgresql://padelzone:padelzone@localhost:5433/padelzone?schema=public"

# Google OAuth (OPCIONAL — deixa vazio se não usares "Continuar com Google").
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
